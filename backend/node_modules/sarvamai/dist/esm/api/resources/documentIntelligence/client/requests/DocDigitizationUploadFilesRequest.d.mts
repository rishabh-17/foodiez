/**
 * @example
 *     {
 *         job_id: "job_id",
 *         files: ["files"]
 *     }
 */
export interface DocDigitizationUploadFilesRequest {
    /** Job identifier returned from Create Job */
    job_id: string;
    /** List of filenames to upload (exactly 1 file: PDF or ZIP) */
    files: string[];
}
