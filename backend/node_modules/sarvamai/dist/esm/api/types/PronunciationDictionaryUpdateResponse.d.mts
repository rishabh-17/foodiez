/**
 * Response returned after successfully updating a pronunciation dictionary. Includes the full updated pronunciation data for verification.
 */
export interface PronunciationDictionaryUpdateResponse {
    /** Unique identifier of the updated dictionary. */
    dictionary_id: string;
    /** The new pronunciation data after the update, organized as `{language_code: {word: pronunciation}}`. */
    updated_pronunciations: Record<string, Record<string, string>>;
}
